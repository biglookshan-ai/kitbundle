{%- assign addon_config = product.metafields.custom.addon_config -%}
{%- assign gift_trigger = product.metafields.custom.gift_trigger -%}
{%- assign has_addon = false -%}
{%- if addon_config != blank and addon_config.value.groups.size > 0 -%}
  {%- assign has_addon = true -%}
{%- endif -%}
{%- comment -%} This product triggers a gift campaign (self-contained stamp). {%- endcomment -%}
{%- assign has_gifts = false -%}
{%- if gift_trigger != blank and gift_trigger.value.size > 0 -%}
  {%- assign has_gifts = true -%}
{%- endif -%}

{%- if has_addon or has_gifts -%}
  <div
    class="cgp-addon"
    data-cgp-addon
    data-product-id="{{ product.id }}"
    data-product-handle="{{ product.handle }}"
    data-currency="{{ cart.currency.iso_code | default: shop.currency }}"
    data-show-strikethrough="{{ block.settings.show_strikethrough }}"
  >
    {%- comment -%} Gift campaigns this product triggers (self-contained). {%- endcomment -%}
    {%- if has_gifts -%}
      <script type="application/json" data-cgp-gifts>
        {{ gift_trigger.value | json }}
      </script>
      <div class="cgp-gift-promo" data-cgp-giftpromo hidden></div>
    {%- endif -%}

    {%- if has_addon -%}
      {%- comment -%} Config is handed to JS as JSON; JS fetches each product's live price/variants. {%- endcomment -%}
      <script type="application/json" data-cgp-config>
        {{ addon_config.value | json }}
      </script>

      <div class="cgp-addon__free" data-cgp-free hidden></div>

      <div class="cgp-addon__bundles" data-cgp-bundles hidden>
        <div class="cgp-addon__sec-head">
          <h2 class="cgp-addon__heading">{{ block.settings.bundle_heading | escape }}</h2>
          <div class="cgp-addon__counter" data-cgp-bundle-counter></div>
        </div>
        <div class="cgp-addon__bundle-list" data-cgp-bundle-list></div>
      </div>

      <div class="cgp-addon__addons" data-cgp-addons hidden>
        <div class="cgp-addon__sec-head">
          <h2 class="cgp-addon__heading">{{ block.settings.heading | escape }}</h2>
          <div class="cgp-addon__counter" data-cgp-counter></div>
        </div>
        <div class="cgp-addon__tabs" data-cgp-tabs role="tablist"></div>
        <div class="cgp-addon__grid" data-cgp-grid aria-live="polite"></div>
      </div>

      <div class="cgp-total" data-cgp-summary hidden></div>
      <button class="cgp-cta" type="button" data-cgp-cta hidden></button>
      <div class="cgp-addon__loading" data-cgp-loading>{{ 'Loading…' }}</div>
    {%- endif -%}
  </div>

  {%- if has_addon -%}
    <div class="cgp-modal" data-cgp-modal hidden>
      <div class="cgp-modal__backdrop" data-cgp-modal-close></div>
      <div class="cgp-modal__dialog" role="dialog" aria-modal="true">
        <button class="cgp-modal__x" data-cgp-modal-close aria-label="Close">&times;</button>
        <div class="cgp-modal__body" data-cgp-modal-body></div>
      </div>
    </div>
  {%- endif -%}

  <script src="{{ 'addon-save.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Add On & Save",
  "target": "section",
  "stylesheet": "addon-save.css",
  "settings": [
    {
      "type": "text",
      "id": "bundle_heading",
      "label": "Bundle section heading",
      "default": "Bundle & Save"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Add-on section heading",
      "default": "Add On & Save"
    },
    {
      "type": "checkbox",
      "id": "show_strikethrough",
      "label": "Show original price struck through",
      "default": true
    }
  ]
}
{% endschema %}
